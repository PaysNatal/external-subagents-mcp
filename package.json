{
  "name": "external-subagents-mcp",
  "version": "0.2.1",
  "description": "A Codex-led read-only worker pool that delegates workspace exploration and high-context analysis to OpenAI-compatible models.",
  "type": "module",
  "bin": {
    "external-subagents-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "docs/configuration.md",
    "docs/README.zh-CN.md",
    "LICENSE",
    ".external-subagents-mcp.example.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "smoke:stdio": "node scripts/smoke-stdio.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "codex",
    "subagents",
    "external-workers",
    "read-only",
    "workspace-exploration",
    "model-routing",
    "token-efficiency",
    "openai-compatible",
    "glm",
    "mimo",
    "deepseek"
  ],
  "author": "PaysNatal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaysNatal/external-subagents-mcp.git"
  },
  "homepage": "https://github.com/PaysNatal/external-subagents-mcp#readme",
  "bugs": {
    "url": "https://github.com/PaysNatal/external-subagents-mcp/issues"
  },
  "engines": {
    "node": ">=20.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jsonrepair": "^3.14.0",
    "minimatch": "^10.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
